# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit real keys.

# NASA Earthdata token (generate at https://urs.earthdata.nasa.gov/profile)
NASA_EARTHDATA_TOKEN=your_token_here

# ACLED API key (register at https://acleddata.com/register/)
ACLED_API_KEY=your_key_here
ACLED_EMAIL=your_email_here

# UNHCR API — no key required, but base URL may change
UNHCR_API_BASE=https://api.unhcr.org/population/v1
